# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL  →  Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key  →  Supabase Dashboard → Project Settings → API → service_role (secret)
# ⚠️  Keep this secret — it bypasses Row Level Security
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Postgres connection string  →  Supabase Dashboard → Project Settings → Database → URI
# Use the "Transaction pooler" URL (port 6543) for serverless / Railway
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# Storage bucket name (create this in Supabase Storage)
SUPABASE_BUCKET=datalens-uploads

# ── App ───────────────────────────────────────────────────────────────────────
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-something-random

# Port (Railway/Render inject this automatically)
PORT=5050
